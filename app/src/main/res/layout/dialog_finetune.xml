<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Graham Formula Fine-Tuning"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="התאם את פרמטרי חישוב הערך האינטרינזי. ערכי גראהם המקוריים מודגשים בירוק."
        android:textSize="14sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Base P/E (מכפיל רווח ללא צמיחה)"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderBasePE"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:valueFrom="5.0"
            android:valueTo="15.0"
            android:stepSize="0.5" />

        <TextView
            android:id="@+id/tvBasePEValue"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="8.5"
            android:textStyle="bold"
            android:background="@drawable/bg_value_square" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Growth Multiplier (מכפיל צמיחה)"
        android:textStyle="bold"
        android:layout_marginTop="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderGrowthMult"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:valueFrom="0.0"
            android:valueTo="4.0"
            android:stepSize="0.1" />

        <TextView
            android:id="@+id/tvGrowthMultValue"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="2.0"
            android:textStyle="bold"
            android:background="@drawable/bg_value_square" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="32dp"
        android:gravity="end">

        <Button
            android:id="@+id/btnReset"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF5722"
            android:text="Reset to Graham" />

        <Button
            android:id="@+id/btnSaveFinetune"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Save &amp; Scan" />
    </LinearLayout>
</LinearLayout>