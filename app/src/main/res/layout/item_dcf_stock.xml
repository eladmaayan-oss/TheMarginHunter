<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvDcfItemTicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AAPL"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:id="@+id/tvDcfItemGrowth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvDcfItemTicker"
            android:text="Expected Growth: 15%"
            android:textSize="12sp"
            android:textColor="#555555" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvDcfItemIntrinsicValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fair Value: $150.00"
                android:textStyle="bold"
                android:textColor="#4CAF50" />

            <TextView
                android:id="@+id/tvDcfItemCurrentPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Price: $120.00"
                android:textSize="14sp" />
        </LinearLayout>

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>